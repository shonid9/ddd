# ===== OpenAI =====
# Your secret OpenAI API key. NEVER commit the real key — keep it only in .env
OPENAI_API_KEY=sk-your-key-here

# Optional model overrides (sensible defaults are used if omitted)
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Deep male voice (onyx / ash recommended); gpt-4o-transcribe is best for Hebrew.
OPENAI_TTS_VOICE=onyx
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# Optional: custom voice delivery style (alien-robotic male by default).
# OPENAI_TTS_INSTRUCTIONS=

# Vision (reads camera frames / screenshots / documents)
OPENAI_VISION_MODEL=gpt-4o

# Live "JARVIS" mode (speech-to-speech: laughs, breaths, barge-in).
# Requires Realtime API access on your account.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=ash

# ===== Server =====
PORT=8787
# Comma separated list of allowed origins for CORS in production (optional).
# In development the Vite dev server proxies /api, so this is usually not needed.
CORS_ORIGIN=
