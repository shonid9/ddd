{
  "name": "oracle-hebrew-voice-avatar",
  "version": "1.0.0",
  "private": true,
  "description": "Oracle - a liquid-eye Hebrew voice AI avatar (audio-reactive WebGL) powered by OpenAI",
  "type": "module",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w client run build",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
